# Local API
ENVIRONMENT=development
DATABASE_URL=sqlite:///data/athena_dev.db
CORS_ORIGINS=http://localhost:3000
AUTH_REQUIRED=false

# Supabase (required for shared preview/production accounts)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Provider-neutral Ask Athena (optional; deterministic grounded fallback works without keys)
AI_PROVIDER=auto
AI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_TIMEOUT_SECONDS=15
AI_MAX_OUTPUT_TOKENS=800
